---
import "../styles/style.css";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>FaboSistemas</title>
        <link
            rel="icon"
            href="https://fabianmartinezrincon.com/favicon/f.svg"
            type="image/x-icon"
        />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        />
        <link
            rel="stylesheet"
            type="text/css"
            href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Aldrich&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <div class="container">
            <!-- Header -->
            <header>
                <div class="profile-image">
                    <img
                        src="https://avatars.githubusercontent.com/u/55964635?v=4"
                        alt="Foto de perfil de Fabian Martinez Rincon"
                        loading="eager"
                        decoding="async"
                    />
                </div>
                <h1>Fabian Martinez Rincon</h1>
                <p class="description">
                   Particular de Informatica | Analista Programador Universitario | Data Engineer
                </p>

                <div class="social-links">
                    <a
                        href="https://www.youtube.com/@FabianMartinezRincon"
                        title="YouTube"
                        target="_blank"
                    >
                        <i class="fab fa-youtube"></i>
                    </a>
                    <a
                        href="https://www.linkedin.com/in/fabian-martinez-rincon/"
                        title="LinkedIn"
                        target="_blank"
                    >
                        <i class="fab fa-linkedin"></i>
                    </a>
                    <a
                        href="https://github.com/Fabian-Martinez-Rincon"
                        title="GitHub"
                        target="_blank"
                    >
                        <i class="fab fa-github"></i>
                    </a>
                    <a
                        href="https://www.instagram.com/fabosistemas/"
                        title="Instagram"
                        target="_blank"
                    >
                        <i class="fab fa-instagram"></i>
                    </a>
                
                </div>
            </header>

            <!-- Main Cards -->
            <main>
                <a
                    href="https://fabianmartinezrincon.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <div class="card">
                        <div class="icon">
                            <img src="/Portafolio.png" alt="Portafolio" loading="lazy" decoding="async" />
                        </div>
                        <div class="card-content">
                            <h2>Portafolio</h2>
                            <p>
                                Proyectos personales y profesionales, artículos técnicos y mi recorrido en software y datos.
                            </p>
                        </div>
                    </div>
                </a>

                <a
                    href="https://github.com/Fabian-Martinez-Rincon/CADP-Programacion-1/tree/master/Algoritmos%20y%20Programacion%201"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <div class="card">
                        <div class="icon">
                            <img
                                src="https://img.icons8.com/?size=100&id=12599&format=png&color=FFFFFF"
                                alt="CodeMatrix"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                        <div class="card-content">
                            <h2>Conceptos de Algoritmos, Datos y Programas (CADP)</h2>
                            <p>
                            Fundamentos de lógica, estructuras básicas y resolución de problemas con ejercicios y parciales resueltos.
                            </p>
                        </div>
                    </div>
                </a>

                <a
                    href="https://github.com/Fabian-Martinez-Rincon/CADP-Programacion-1"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <div class="card">
                        <div class="icon">
                            <img
                                src="https://img.icons8.com/?size=100&id=12599&format=png&color=FFFFFF"
                                alt="CodeMatrix"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                        <div class="card-content">
                            <h2>Algoritmos y Programación 1 (AyP 1)</h2>
                            <p>Prácticas guiadas, evaluaciones y material de apoyo enfocado en complejidad temporal para CDO.
                            </p>
                        </div>
                    </div>
                </a>

                <a
                    href="https://github.com/Fabian-Martinez-Rincon/Taller-de-Programacion"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <div class="card">
                        <div class="icon">
                            <img
                                src="https://img.icons8.com/?size=100&id=12599&format=png&color=FFFFFF"
                                alt="CodeMatrix"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                        <div class="card-content">
                            <h2>Taller de Programación</h2>
                            <p>
                            Repositorio general del taller con entregas, ejemplos de código y recursos usados durante la cursada.
                            </p>
                        </div>
                    </div>
                </a>

                <a
                    href="https://github.com/Fabian-Martinez-Rincon/Taller-de-Programacion/tree/main/Algoritmos%20y%20Programacion%202"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <div class="card">
                        <div class="icon">
                            <img
                                src="https://img.icons8.com/?size=100&id=12599&format=png&color=FFFFFF"
                                alt="CodeMatrix"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                        <div class="card-content">
                            <h2>Algoritmos y Programación 2 (AyP 2)</h2>
                            <p>
                            Contenido avanzado con apuntes, prácticas y parciales para afianzar técnicas y aprobar la materia.
                            </p>
                        </div>
                    </div>
                </a>


            </main>

            <!-- YouTube Section -->
            <section class="youtube-section">
                <h2><i class="fas fa-video"></i> Último video de YouTube</h2>
                <div class="video-container">
                    <div class="video-embed">
                        <iframe
                            width="100%"
                            height="315"
                            src="https://www.youtube.com/embed/eBSd3jINKd4"
                            title="¿Qué es Linux? El sistema operativo que domina el mundo"
                            frameborder="0"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            allowfullscreen
                            style="border-radius: 8px;"
                        >
                        </iframe>
                    </div>
                </div>

                <script>
                    function copyLink() {
                        const videoUrl =
                            "https://www.youtube.com/watch?v=eBSd3jINKd4";
                        navigator.clipboard.writeText(videoUrl).then(() => {
                            alert("¡Vínculo copiado al portapapeles!");
                        });
                    }
                </script>
            </section>
        </div>
    </body>
</html>
